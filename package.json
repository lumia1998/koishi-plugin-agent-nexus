{
  "name": "koishi-plugin-agent-nexus",
  "description": "SSH-backed code agent gateway for ChatLuna (Hermes / OpenClaw / Claude Code / OpenCode / Codex)",
  "version": "0.1.29",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist"
  ],
  "type": "commonjs",
  "author": "lumia1998",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumia1998/koishi-plugin-AgentNexus.git"
  },
  "bugs": {
    "url": "https://github.com/lumia1998/koishi-plugin-AgentNexus/issues"
  },
  "homepage": "https://github.com/lumia1998/koishi-plugin-AgentNexus#readme",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node -e \"require(require('path').join(process.env.INIT_CWD || process.cwd(), 'scripts/build.cjs'))\"",
    "build:client": "node -e \"require(require('path').join(process.env.INIT_CWD || process.cwd(), 'scripts/build-client.cjs'))\"",
    "typecheck": "node -e \"require(require('path').join(process.env.INIT_CWD || process.cwd(), 'scripts/typecheck.cjs'))\"",
    "test": "node -e \"require(require('path').join(process.env.INIT_CWD || process.cwd(), 'scripts/test.cjs'))\"",
    "test:agents": "node ./scripts/smoke-agents.cjs"
  },
  "koishi": {
    "description": {
      "zh": "通过 SSH 委托 Hermes/OpenClaw/Claude Code/OpenCode/Codex 执行任务，并同步 Skills",
      "en": "SSH gateway to code agents with skill sync and terminal UI"
    },
    "service": {
      "required": [
        "chatluna"
      ],
      "optional": [
        "console",
        "server",
        "chatluna_storage"
      ]
    }
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "chatluna",
    "ssh",
    "agent",
    "hermes",
    "openclaw",
    "claude",
    "opencode",
    "codex"
  ],
  "peerDependencies": {
    "koishi": "^4.18.0",
    "koishi-plugin-chatluna": "*",
    "koishi-plugin-chatluna-storage-service": "^1.0.6"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@koishijs/client": "^5.29.0",
    "@langchain/core": "^0.3.40",
    "@xterm/addon-fit": "^0.10.0",
    "element-plus": "^2.14.3",
    "ssh2": "^1.16.0",
    "xterm": "^5.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@koishijs/plugin-console": "^5.29.0",
    "@types/node": "^20.14.0",
    "@types/ssh2": "^1.15.0",
    "@vue/shared": "^3.5.39",
    "esbuild": "0.21.5",
    "koishi": "^4.17.0",
    "typescript": "^5.6.0",
    "vue": "^3.5.39"
  },
  "allowScripts": {
    "ssh2": true,
    "esbuild": true,
    "vue-demi": true,
    "@parcel/watcher": true
  },
  "overrides": {
    "langsmith": "^0.6.3"
  }
}
